#!/bin/bash
#
# Pre-push hook for dev/frontend.
# Runs frontend unit tests (and Drupal PHPUnit when DDEV is available).
#
# Skip with: git push --no-verify
#

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# Detect DDEV once
DDEV_AVAILABLE=false
if command -v ddev >/dev/null 2>&1 && ddev describe >/dev/null 2>&1; then
    DDEV_AVAILABLE=true
fi

echo "[pre-push] Running frontend unit tests..."
if [ "$DDEV_AVAILABLE" = true ]; then
    ddev exec -s node-dev "cd /var/www/html/frontend && pnpm run test:unit"
else
    pnpm run test:unit
fi

echo "[pre-push] Frontend unit tests passed."

if [ "$DDEV_AVAILABLE" = true ]; then
    echo "[pre-push] Running Drupal PHPUnit tests..."

    if ddev exec 'test -f /var/www/html/vendor/bin/phpunit' 2>/dev/null; then
        TEST_DIRS=""
        for dir in \
          profiles/contrib/markaspot/modules/markaspot_group/tests/src/Unit/ \
          profiles/contrib/markaspot/modules/markaspot_open311/tests/src/Unit/ \
          profiles/contrib/markaspot/modules/markaspot_vision/tests/src/Unit/ \
          profiles/contrib/markaspot/modules/markaspot_escalation/tests/src/Unit/ \
          profiles/contrib/markaspot/modules/markaspot_tenant_admin/tests/src/Unit/ \
          profiles/contrib/markaspot/modules/markaspot_fastmap/tests/src/Unit/; do
          if ddev exec "test -d /var/www/html/web/$dir" 2>/dev/null; then
            TEST_DIRS="$TEST_DIRS $dir"
          fi
        done

        if [ -z "$TEST_DIRS" ]; then
            echo "[pre-push] No Drupal test directories found, skipping"
        else
            ddev exec "cd web && ../vendor/bin/phpunit --bootstrap core/tests/bootstrap.php $TEST_DIRS"
        fi
    else
        echo "[pre-push] Skipping Drupal tests (phpunit not found, run composer install)"
    fi
else
    echo "[pre-push] Skipping Drupal tests (DDEV not running)"
fi
